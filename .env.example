# Logging
LOG_LEVEL=INFO

# CORS (comma-separated origins, or "*" for dev)
CORS_ORIGINS=*

# API Authentication (required — comma-separated keys)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=your-api-key-here

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=regulahub
DB_USER=regulahub
DB_PASSWORD=regulahub_dev

# Credential encryption (Fernet key — 44 chars, base64)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# Admin UI — API base URL (overridden in docker-compose for container networking)
ADMIN_API_URL=http://localhost:8000

# Admin UI — storage secret for session persistence (change in production)
ADMIN_STORAGE_SECRET=regulahub-admin-default-secret-change-me

# Seed demo credentials for non-SISREG systems (ESUS, SIGA, CARE, SER)
SEED_DEMO_CREDENTIALS=true

# Seed credentials path (encrypted JSON file for initial DB seeding)
# The seed file is auto-loaded on startup via: python -m regulahub.scripts.seed_credentials
# Generate with: python -m regulahub.scripts.export_credentials
# SEED_CREDENTIALS_PATH=docker/seed/credentials.enc.json
