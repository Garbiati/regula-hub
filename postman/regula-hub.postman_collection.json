									"host": [
										"{{base_url}}"
									],
									"path": [
										"raw",
										"videofonista",
										"appointments",
										"1234567890"
									]
								}
							},
							"status": "OK",
							"code": 200,
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"detail\": {\n    \"code\": \"1234567890\",\n    \"confirmation_key\": \"CONF-KEY-12345\",\n    \"cns\": \"123456789012345\",\n    \"appointment_date\": \"15/03/2026\",\n    \"doctor_solicitation\": \"DR. MEDICO SOLICITANTE\",\n    \"doctor_crm\": \"CRM-12345\",\n    \"doctor_solicitation_cpf\": \"123.456.789-00\",\n    \"priority\": \"ALTA\",\n    \"regulatory_center\": \"CENTRAL DE REGULACAO AM\",\n    \"cnes\": \"2018756\",\n    \"department\": \"HOSPITAL REGIONAL DE MANAUS\",\n    \"videocall_operator\": \"OPERADOR VIDEOCALL\",\n    \"solicitation_operator\": \"OPERADOR SOLICITACAO\",\n    \"observations\": \"Paciente com historico de HAS\",\n    \"best_phone\": {\n      \"ddd\": \"92\",\n      \"number\": \"98765-4321\",\n      \"phone_type\": \"mobile\"\n    }\n  }\n}"
						}
					]
				}
			]
		},
		{
			"name": "Sync (Pipeline)",
			"description": "Visibility and control of the integration pipeline. All endpoints require `X-API-Key` header.\n\n**Endpoints:**\n- `GET /sync/status` — Worker status and last execution summary\n- `GET /sync/appointments?date=YYYY-MM-DD` — Integrated appointments for a date\n- `POST /sync/trigger?date=YYYY-MM-DD` — Trigger pipeline execution",
			"item": [
				{
					"name": "Worker Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Has worker status fields', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('enabled');",
									"    pm.expect(json).to.have.property('is_running');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-API-Key",
								"value": "{{api_key}}",
								"description": "API key for authentication"
							}
						],
						"url": {
							"raw": "{{base_url}}/sync/status",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"sync",
								"status"
							]
						},
						"description": "Returns the current worker status (enabled/running) and the last sync execution summary.\n\n**Response Fields:**\n- `enabled` — Whether the background worker is enabled\n- `is_running` — Whether the worker is currently executing\n- `last_execution` — Summary of the most recent execution (null if none)"
					},
