								"exec": [
									"var code = pm.collectionVariables.get('appointment_code');",
									"if (!code) {",
									"    console.warn('appointment_code not set. Run a listing request first to auto-populate it.');",
									"}"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Detail has code', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.detail).to.be.an('object');",
									"    pm.expect(json.detail.code).to.be.a('string');",
									"});",
									"",
									"pm.test('Phone is object or null', function () {",
									"    var phone = pm.response.json().detail.best_phone;",
									"    if (phone !== null) {",
									"        pm.expect(phone).to.have.property('ddd');",
									"        pm.expect(phone).to.have.property('number');",
									"        pm.expect(phone).to.have.property('phone_type');",
									"    }",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-API-Key",
								"value": "{{api_key}}",
								"description": "API key for authentication"
							}
						],
						"url": {
							"raw": "{{base_url}}/raw/videofonista/appointments/{{appointment_code}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"raw",
								"videofonista",
								"appointments",
								"{{appointment_code}}"
							]
						},
						"description": "Returns detailed appointment information using the Videofonista profile.\n\nSame response schema as `/appointments/{code}` but explicitly forces the Videofonista profile.\n\n**Path Parameters:**\n- `code` — The appointment code (auto-populated from listing requests)\n\n**Status Codes:**\n- `200` — Success\n- `401` — Invalid SisReg credentials\n- `422` — Invalid code format\n- `503` — SisReg session expired after retries"
					},
					"response": [
						{
							"name": "Detail with phone",
							"originalRequest": {
								"method": "GET",
								"header": [
									{
										"key": "X-API-Key",
										"value": "{{api_key}}",
										"description": "API key for authentication"
									}
								],
								"url": {
