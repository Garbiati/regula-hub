								}
							},
							"status": "Service Unavailable",
							"code": 503,
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"status\": \"unhealthy\",\n  \"service\": \"regula-hub\",\n  \"version\": \"0.1.0\",\n  \"uptime_seconds\": 5.0,\n  \"timestamp\": \"2026-03-09T10:30:45.123456+00:00\",\n  \"checks\": {\n    \"sisreg_reachable\": {\n      \"status\": \"unhealthy\",\n      \"latency_ms\": null,\n      \"detail\": \"Service unavailable\"\n    }\n  }\n}"
